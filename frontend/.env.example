# ─────────────────────────────────────────────────────────────────
# SnapGram Frontend — Environment Variables
# ─────────────────────────────────────────────────────────────────
#
# HOW TO USE:
#   Local development:  cp .env.example .env.local
#   Vercel production:  Add these in Vercel → Project → Settings → Environment Variables
#
# NEVER commit .env.local or .env to Git (already in .gitignore)
# ─────────────────────────────────────────────────────────────────

# Your deployed Render backend URL (no trailing slash)
# Example: https://snapgram-backend.onrender.com/api
VITE_API_URL=https://YOUR_RENDER_APP.onrender.com/api

# WebSocket URL — use wss:// for https backends
# Example: wss://snapgram-backend.onrender.com/ws
VITE_WS_URL=wss://YOUR_RENDER_APP.onrender.com/ws
