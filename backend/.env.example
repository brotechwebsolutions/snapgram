# ─────────────────────────────────────────────────────────────────
# SnapGram Backend — Environment Variables
# ─────────────────────────────────────────────────────────────────
#
# HOW  TO USE:
#   Local development:  cp .env.example .env  (then fill in values)
#   Render production:  Add these in Render → Service → Environment
#
# NEVER commit .env to Git (already in .gitignore)
# ─────────────────────────────────────────────────────────────────

# ── MongoDB Atlas ───────────────────────────────────────────
# Get from: cloud.mongodb.com → Connect → Drivers → copy string
# Replace <username>, <password>, and add /snapgram before ?
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/snapgram?retryWrites=true&w=majority

# ── JWT Secret ──────────────────────────────────────────────
# MUST be 32+ characters. Generate one:
#   Mac/Linux: openssl rand -hex 32
#   Online:    https://generate-secret.vercel.app/32
JWT_SECRET=replace-this-with-a-32-plus-character-random-string

# ── Cloudinary (Image Storage) ──────────────────────────────
# Get from: cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_api_secret_here

# ── Gmail SMTP (Email Service) ──────────────────────────────
# Use your Gmail address and an APP PASSWORD (not your login password)
# Create App Password: Google Account → Security → 2FA → App Passwords
MAIL_USERNAME=yourapp@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── App URLs ────────────────────────────────────────────────
# After deploying frontend to Vercel, set FRONTEND_URL to your Vercel URL
# Local development:
FRONTEND_URL=http://localhost:5173
# Production example:
# FRONTEND_URL=https://snapgram.vercel.app

# Your Render backend URL (used in email verification links)
BASE_URL=http://localhost:8080
# Production example:
# BASE_URL=https://snapgram-backend.onrender.com

# ── Server Port ─────────────────────────────────────────────
# Render sets PORT automatically — don't change this
PORT=8080
